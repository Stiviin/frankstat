datasource db {
  provider = "postgresql"
   url      = env("DATABASE_URL")
}
generator client {
  provider = "prisma-client-js"
}

// prisma/schema.prisma

model User {
  id            String   @id @default(cuid())
  fullName      String
  email         String   @unique
  phone         String?
  passwordHash  String
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  orders        Order[]  // Add this relation
}

model Order {
  id            String      @id @default(cuid())
  userId        String?
  user          User?       @relation(fields: [userId], references: [id])
  
  // Service Details
  serviceId     String      // e.g. "banners", "posters"
  serviceName   String
  dimensions    String?     // e.g. "4x4 ft" or "A3"
  quantity      Int         @default(1)
  finishType    String?     // e.g. "glossy", "matte"
  specialNotes  String?
  
  // Financials
  totalPrice    Float       // Total calculated price
  depositAmount Float       // 50% deposit required
  
  // Artwork
  artworkUrl    String      // Path to the uploaded file
  
  // M-Pesa & Status
  mpesaPhone    String      // Phone number used for payment
  status        OrderStatus @default(PENDING_PAYMENT)
  
  // Transaction tracking
  merchantRequestID String?
  checkoutRequestID String?
  mpesaReceipt     String?
  
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([status])
}

enum OrderStatus {
  PENDING_PAYMENT
  PAID_DEPOSIT
  PROCESSING
  READY
  COMPLETED
  CANCELLED
}